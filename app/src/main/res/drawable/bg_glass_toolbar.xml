<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid glass surface: semi-transparent + subtle white stroke -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fill: 80% opacity system grouped bg -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_surface" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Stroke: subtle white border for glass depth -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="@color/glass_stroke" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
