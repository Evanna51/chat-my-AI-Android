<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid glass bottom bar: flat top, no top corners -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_surface" />
        </shape>
    </item>
    <!-- Top border line for glass separation -->
    <item android:bottom="-2dp" android:left="-2dp" android:right="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="0.5dp" android:color="@color/ios_separator" />
        </shape>
    </item>
</layer-list>
