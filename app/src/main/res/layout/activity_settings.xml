<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ios_grouped_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/ios_grouped_bg"
        app:elevation="0dp"
        app:title="@string/settings"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ios_grouped_bg"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Section header: 模型管理 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/model_management"
                android:textSize="13sp"
                android:textColor="@color/ios_section_label"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp" />

            <include
                android:id="@+id/includeModelManagement"
                layout="@layout/layout_model_management"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <!-- Section header: 设置选项 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_options"
                android:textSize="13sp"
                android:textColor="@color/ios_section_label"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="8dp" />

            <!-- 设置选项: grouped card with all three items -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/ios_cell_bg"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Row: 常规设置 (expandable) -->
                    <LinearLayout
                        android:id="@+id/headerGeneral"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:minHeight="56dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/general_settings"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/colorOnSurface" />
                        <ImageView
                            android:id="@+id/iconGeneralExpand"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/ios_section_label" />
                    </LinearLayout>

                    <!-- Expanded content for 常规设置 -->
                    <LinearLayout
                        android:id="@+id/expandGeneral"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/theme"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:layout_marginBottom="6dp" />
                        <RadioGroup
                            android:id="@+id/radioTheme"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="14dp">
                            <RadioButton
                                android:id="@+id/themeLight"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minHeight="40dp"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:text="@string/theme_light" />
                            <RadioButton
                                android:id="@+id/themeDark"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:minHeight="40dp"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:text="@string/theme_dark" />
                            <RadioButton
                                android:id="@+id/themeSystem"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:minHeight="40dp"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:text="@string/theme_system" />
                        </RadioGroup>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/theme_color"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:layout_marginBottom="6dp" />
                        <RadioGroup
                            android:id="@+id/radioThemeColor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="14dp">
                            <RadioButton
                                android:id="@+id/colorBlue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minHeight="40dp"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:text="蓝" />
                            <RadioButton
                                android:id="@+id/colorGreen"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:minHeight="40dp"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:text="绿" />
                            <RadioButton
                                android:id="@+id/colorPurple"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:minHeight="40dp"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:text="紫" />
                            <RadioButton
                                android:id="@+id/colorOrange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:minHeight="40dp"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:text="橙" />
                        </RadioGroup>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/font_size"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:layout_marginBottom="6dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <SeekBar
                                android:id="@+id/seekFontSize"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:max="4"
                                android:progress="1" />
                            <TextView
                                android:id="@+id/textFontSizeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:minWidth="32dp"
                                android:text="14" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnNewChat"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/new_chat" />
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnExport"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/export" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Separator -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="16dp"
                        android:background="@color/ios_separator" />

                    <!-- Row: 模型配置 -->
                    <LinearLayout
                        android:id="@+id/cardModelConfig"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:minHeight="56dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/model_config"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/colorOnSurface" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/ios_section_label" />
                    </LinearLayout>

                    <!-- Separator -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="16dp"
                        android:background="@color/ios_separator" />

                    <!-- Row: 人物记忆服务 -->
                    <LinearLayout
                        android:id="@+id/cardCharacterMemory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:minHeight="56dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/character_memory_settings"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="?attr/colorOnSurface" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/ios_section_label" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
