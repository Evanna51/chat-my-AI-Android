<?xml version="1.0" encoding="utf-8"?>
<!-- WhatsApp + iOS 2026 style conversation row -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/ios_cell_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        android:background="?attr/selectableItemBackground"
        android:minHeight="64dp">

        <!-- Avatar circle -->
        <TextView
            android:id="@+id/textConversationAvatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="12dp"
            android:gravity="center"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimary"
            android:background="@drawable/bg_avatar_circle"
            android:text="A" />

        <!-- Title + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/textConversationTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/textConversationTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/ios_section_label" />
            </LinearLayout>

            <TextView
                android:id="@+id/textConversationOutline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textSize="13sp"
                android:textColor="@color/ios_section_label"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

    <!-- Compact actions row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingStart="70dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <ImageButton
            android:id="@+id/btnOutline"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/generate_outline"
            android:padding="6dp"
            android:src="@drawable/ic_action_regenerate"
            app:tint="@color/ios_section_label" />

        <ImageButton
            android:id="@+id/btnCategory"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/set_category"
            android:padding="6dp"
            android:src="@drawable/ic_action_category"
            app:tint="@color/ios_section_label" />

        <ImageButton
            android:id="@+id/btnPin"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/toggle_pin"
            android:padding="6dp"
            android:src="@drawable/ic_action_pin"
            app:tint="@color/ios_section_label" />

        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/toggle_favorite"
            android:padding="6dp"
            android:src="@drawable/ic_action_favorite"
            app:tint="@color/ios_section_label" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete_conversation"
            android:padding="6dp"
            android:src="@drawable/ic_action_delete"
            app:tint="@color/ios_destructive" />
    </LinearLayout>

    <!-- iOS-style separator (indented to align with text) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="70dp"
        android:background="@color/ios_separator" />

</LinearLayout>
