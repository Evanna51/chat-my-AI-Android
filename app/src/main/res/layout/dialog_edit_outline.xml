<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_ios_dialog">

    <!-- 标题（知情约束时文字变化） -->
    <TextView
        android:id="@+id/dialogOutlineTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="新增大纲"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:paddingTop="18dp"
        android:paddingBottom="14dp"
        android:paddingHorizontal="20dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="?attr/colorOutline"
        android:alpha="0.3" />

    <!-- 类型 chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupOutlineType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTypeChapter"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="章节"
                android:textColor="@color/chip_outline_type_text_selector"
                app:chipBackgroundColor="@color/chip_outline_type_bg_selector"
                app:chipEndPadding="10dp"
                app:chipStartPadding="10dp"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false"
                app:textEndPadding="0dp"
                app:textStartPadding="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTypeTask"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="人物资料"
                android:textColor="@color/chip_outline_type_text_selector"
                app:chipBackgroundColor="@color/chip_outline_type_bg_selector"
                app:chipEndPadding="10dp"
                app:chipStartPadding="10dp"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false"
                app:textEndPadding="0dp"
                app:textStartPadding="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTypeWorld"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="世界背景"
                android:textColor="@color/chip_outline_type_text_selector"
                app:chipBackgroundColor="@color/chip_outline_type_bg_selector"
                app:chipEndPadding="10dp"
                app:chipStartPadding="10dp"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false"
                app:textEndPadding="0dp"
                app:textStartPadding="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTypeKnowledge"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="知情约束"
                android:textColor="@color/chip_outline_type_text_selector"
                app:chipBackgroundColor="@color/chip_outline_type_bg_selector"
                app:chipEndPadding="10dp"
                app:chipStartPadding="10dp"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false"
                app:textEndPadding="0dp"
                app:textStartPadding="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTypeMaterial"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="资料"
                android:textColor="@color/chip_outline_type_text_selector"
                app:chipBackgroundColor="@color/chip_outline_type_bg_selector"
                app:chipEndPadding="10dp"
                app:chipStartPadding="10dp"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false"
                app:textEndPadding="0dp"
                app:textStartPadding="0dp" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="?attr/colorOutline"
        android:alpha="0.15" />

    <!-- 普通标题输入（非知情约束时显示） -->
    <EditText
        android:id="@+id/editOutlineTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:hint="标题，例如：第1章"
        android:inputType="textCapSentences"
        android:maxLines="1"
        android:padding="16dp"
        android:textSize="15sp"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="@color/ios_section_label" />

    <!-- 知情约束：章节多选行（选中 chip 时显示） -->
    <LinearLayout
        android:id="@+id/layoutKnowledgeScope"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="适用章节"
            android:textSize="14sp"
            android:textColor="@color/ios_section_label"
            android:layout_marginEnd="12dp" />

        <!-- 可点击的选择行 -->
        <LinearLayout
            android:id="@+id/btnKnowledgePicker"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:background="@drawable/bg_knowledge_picker"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/textKnowledgeSelection"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="全部"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_action_expand_left"
                android:rotation="270"
                android:layout_marginStart="4dp"
                app:tint="@color/ios_section_label" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="?attr/colorOutline"
        android:alpha="0.15" />

    <!-- 内容输入 -->
    <EditText
        android:id="@+id/editOutlineContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:hint="内容"
        android:gravity="top|start"
        android:inputType="textMultiLine|textCapSentences"
        android:minLines="5"
        android:maxLines="12"
        android:padding="16dp"
        android:textSize="15sp"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="@color/ios_section_label"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical"
        android:scrollHorizontally="false" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="?attr/colorOutline"
        android:alpha="0.3" />

    <!-- iOS 式按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="取消"
            android:textSize="16sp"
            android:textColor="@color/ios_section_label"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="?attr/colorOutline"
            android:alpha="0.3" />

        <TextView
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="保存"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
