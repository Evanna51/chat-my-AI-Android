<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AIChat" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">?attr/colorPrimaryLight</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorPrimarySubtle">@color/primary_blue_subtle</item>
        <item name="colorPrimaryLight">@color/primary_blue_light</item>
        <item name="colorPrimaryDeep">@color/primary_blue_deep</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.AIChat.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.AIChat.MaterialAlertDialog</item>
    </style>

    <style name="Theme.AIChat.Blue" parent="Theme.AIChat">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimarySubtle">@color/primary_blue_subtle</item>
        <item name="colorPrimaryLight">@color/primary_blue_light</item>
        <item name="colorPrimaryDeep">@color/primary_blue_deep</item>
    </style>

    <style name="Theme.AIChat.Green" parent="Theme.AIChat">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimarySubtle">@color/primary_green_subtle</item>
        <item name="colorPrimaryLight">@color/primary_green_light</item>
        <item name="colorPrimaryDeep">@color/primary_green_deep</item>
    </style>

    <style name="Theme.AIChat.Purple" parent="Theme.AIChat">
        <item name="colorPrimary">@color/primary_purple</item>
        <item name="colorPrimarySubtle">@color/primary_purple_subtle</item>
        <item name="colorPrimaryLight">@color/primary_purple_light</item>
        <item name="colorPrimaryDeep">@color/primary_purple_deep</item>
    </style>

    <style name="Theme.AIChat.Orange" parent="Theme.AIChat">
        <item name="colorPrimary">@color/primary_orange</item>
        <item name="colorPrimarySubtle">@color/primary_orange_subtle</item>
        <item name="colorPrimaryLight">@color/primary_orange_light</item>
        <item name="colorPrimaryDeep">@color/primary_orange_deep</item>
    </style>

    <style name="TextAppearance.AIChat.Toolbar.Title.Small" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
    </style>

    <style name="TextAppearance.AIChat.Toolbar.Subtitle" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Widget.AIChat.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <!-- iOS 2026 公共 styles -->
    <style name="Widget.AIChat.IOSSectionHeader">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/ios_section_label</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="Widget.AIChat.IOSListRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="Widget.AIChat.GlassCard">
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
    </style>

    <style name="ThemeOverlay.AIChat.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="backgroundTint">@color/dialog_surface_bg</item>
        <item name="android:windowBackground">@drawable/bg_material_alert_dialog</item>
        <item name="colorSurface">@color/dialog_surface_bg</item>
        <item name="elevationOverlayEnabled">false</item>
    </style>
</resources>
