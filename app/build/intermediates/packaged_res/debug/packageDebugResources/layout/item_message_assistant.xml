<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:paddingVertical="4dp">

    <TextView
        android:id="@+id/textTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:textSize="12sp"
        android:textColor="@color/chat_meta_text_color" />

    <LinearLayout
        android:id="@+id/layoutReasoning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="4dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/textReasoningHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thinking"
            android:textStyle="bold"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/chat_meta_text_color"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp" />
        <TextView
            android:id="@+id/textReasoningContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="300dp"
            android:layout_marginTop="2dp"
            android:padding="10dp"
            android:textSize="13sp"
            android:textColor="@color/chat_reasoning_text_color"
            android:background="@drawable/bubble_reasoning"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/textContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxWidth="300dp"
        android:padding="12dp"
        android:background="@drawable/bubble_assistant"
        android:textColor="@color/chat_assistant_text_color"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/textUsage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textSize="12sp"
        android:textColor="@color/chat_meta_text_color"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageButton
            android:id="@+id/actionEdit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_action_edit"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="编辑" />
        <ImageButton
            android:id="@+id/actionCopy"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_action_copy"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="复制" />
        <ImageButton
            android:id="@+id/actionDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="14dp"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_action_delete"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="删除" />
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />
        <TextView
            android:id="@+id/textCollapseToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp"
            android:text="▼ 展开"
            android:textSize="12sp"
            android:textColor="@color/chat_meta_text_color"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>
</LinearLayout>
