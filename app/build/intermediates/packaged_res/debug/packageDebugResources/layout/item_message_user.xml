<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="end"
    android:paddingVertical="4dp">

    <TextView
        android:id="@+id/textTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:textSize="12sp"
        android:textColor="@color/chat_meta_text_color" />

    <TextView
        android:id="@+id/textContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:padding="12dp"
        android:background="@drawable/bubble_user"
        android:textColor="@color/chat_user_text_color"
        android:textSize="16sp" />

    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:visibility="gone">
        <ImageButton
            android:id="@+id/actionRegenerate"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_action_regenerate"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="重新生成" />
        <ImageButton
            android:id="@+id/actionEdit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_action_edit"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="编辑" />
        <ImageButton
            android:id="@+id/actionCopy"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_action_copy"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="复制" />
        <ImageButton
            android:id="@+id/actionDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="14dp"
            android:padding="9dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_action_delete"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="删除" />
    </LinearLayout>
</LinearLayout>
